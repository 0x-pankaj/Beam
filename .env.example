# ─────────────────────────────────────────────────────────────────────────────
# Beam env TEMPLATE — copy to .env.local and fill in real values there.
# Never put real secrets in this file. (.env* is gitignored anyway.)
# ─────────────────────────────────────────────────────────────────────────────

# Particle Universal Accounts — https://dashboard.particle.network/
# Create a project + a WEB app, then copy its credentials.
# The same values are used by the browser app (NEXT_PUBLIC_*) and the headless
# spike (the non-prefixed copies below).
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=

# Magic embedded wallet — https://dashboard.magic.link/  (Publishable key, pk_live_…)
NEXT_PUBLIC_MAGIC_API_KEY=

# Google One Tap login (optional). Google Cloud OAuth client ID (…apps.googleusercontent.com).
# Must match the Client ID entered in the Magic dashboard's Google Social Login.
# When unset, the app silently falls back to email login only.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: Base mainnet RPC (defaults to https://mainnet.base.org)
NEXT_PUBLIC_BASE_RPC_URL=

# Optional: Ethereum mainnet RPC for ENS resolution on the "Pay anyone" page
# (defaults to a public endpoint). ENS lives on Ethereum mainnet.
NEXT_PUBLIC_ETH_RPC_URL=

# Optional: persistent link store for deployment (local dev needs nothing).
# Add a Vercel KV or Upstash Redis integration and these get injected; Beam
# auto-detects either pair and falls back to in-memory when absent.
#   Vercel KV:  KV_REST_API_URL / KV_REST_API_TOKEN
#   Upstash:    UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Escrow relayer (makes "send" links real, guaranteed payouts) ─────────────
# The Beam holding wallet. A sender's Universal Account deposits USDC here at
# create-time; on a valid claim the server pays the recipient out from here, so
# the recipient is guaranteed to get paid without the sender returning online.
# This wallet must hold a little ETH on Arbitrum (gas) + the USDC it pays out.
# SERVER-ONLY — never prefix with NEXT_PUBLIC_. When unset, "send" links fall
# back to the legacy sender-pays-on-claim flow.
BEAM_RELAYER_PRIVATE_KEY=
# Optional: Arbitrum RPC override for on-chain verification + payouts
# (defaults to https://arb1.arbitrum.io/rpc)
ARBITRUM_RPC_URL=

# Optional: email links to recipients via Resend (https://resend.com). When
# unset, the "email it to them" field simply does nothing.
RESEND_API_KEY=
RESEND_FROM="Beam <onboarding@resend.dev>"
# Used in notification email links (defaults to the deployed URL)
NEXT_PUBLIC_APP_URL=

# ── Headless spike only (pnpm spike) ─────────────────────────────────────────
# Same Particle credentials as above, without the NEXT_PUBLIC_ prefix:
PARTICLE_PROJECT_ID=
PARTICLE_CLIENT_KEY=
PARTICLE_APP_ID=
# Throwaway 0x… private key whose EOA holds a little USDC on a supported mainnet
# (UA cross-chain is MAINNET ONLY — uses REAL funds):
SPIKE_PRIVATE_KEY=
SPIKE_RECEIVER=
SPIKE_AMOUNT=0.5
